# ============================================
# Atnasya Health Tracker — Backend Environment
# ============================================
# Copy this file to .env and fill in your values.

# Server
PORT=3001
NODE_ENV=development

# MongoDB Atlas connection string
# Get yours from: https://cloud.mongodb.com → Database → Connect → Drivers
# Replace <username>, <password>, <cluster> with your Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/atnasya?retryWrites=true&w=majority

# Firebase Admin SDK — private key JSON (one line, escaped)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then minify the JSON to a single line and paste it here.
# Example: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT=your_firebase_service_account_json_here

# Gemini AI API key (for AI chat/insights feature)
GEMINI_API_KEY=your_gemini_api_key_here

# Dev auth bypass — set to "1" to allow dev tokens without Firebase
# In dev, use Authorization: Bearer dev:<firebaseUid> to skip Firebase verification
ATNASYA_DEV_AUTH=1

# Atnasya Health Tracker — Backend Environment
# Copy this file to .env and fill in your values.

# Server
PORT=3001
NODE_ENV=development

# MongoDB Atlas connection string
# Get yours from: https://cloud.mongodb.com → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:***@cluster0.xxxxx.mongodb.net/atnasya?retryWrites=true&w=majority

# Firebase Admin service account (JSON stringified — must be single line)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then minify the JSON to a single line and paste it here.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# AI API Keys (optional)
OPENGEMINI_API_KEY=your_gemini_api_key_here
OPENCODE_ZEN_API_KEY=your_opencode_zen_api_key_here
OPENCODE_ZEN_BASE_URL=https://api.opencode.ai/v1

# Dev auth bypass — set to "1" to allow dev tokens without Firebase
# In dev, use Authorization: Bearer dev:<uid> to skip Firebase verification
ATNASYA_DEV_AUTH=1
